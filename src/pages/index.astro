---
import Layout from '../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { pieces } from '../data/pieces.js';

// Pre-optimise overlay gallery images at build time so browser JS gets WebP URLs
const browserPieces = await Promise.all(
  pieces.map(async (piece) => {
    const additionalImages = await Promise.all(
      (piece.additionalImages || []).map(async (imgMeta) => {
        const opt = await getImage({ src: imgMeta, format: 'webp', quality: 85, width: 1200 });
        return { src: opt.src };
      })
    );
    return {
      id: piece.id,
      name: piece.name,
      year: piece.year,
      materials: piece.materials,
      dimensions: piece.dimensions,
      description: piece.description,
      additionalImages,
    };
  })
);
---

<Layout title="Furniture — Frome">

  <!-- Full-screen scroll-snap gallery -->
  <div class="gallery" id="gallery">
    {pieces.map((piece, i) => (
      <section
        class="gallery__slide"
        data-piece-id={piece.id}
        aria-label={piece.name}
      >
        <Image
          src={piece.mainImage}
          alt={piece.name}
          class="gallery__img"
          format="webp"
          quality={90}
          width={1920}
          loading="eager"
          draggable="false"
          style={piece.objectPosition ? `object-position: ${piece.objectPosition}` : undefined}
        />
        <p class="gallery__slide-title">{piece.name}</p>
      </section>
    ))}
  </div>

  <!-- Site header -->
  <div class="site-header">
    <p class="site-title">FRANK STYLES</p>
    <button class="info-btn" id="info-btn" aria-label="Information">
      <svg class="info-btn__circle" id="info-circle" viewBox="0 0 100 100" aria-hidden="true"></svg>
    </button>
  </div>

  <!-- Full-screen overlay (about/contact) -->
  <div class="main-overlay" id="main-overlay" aria-hidden="true"></div>
  <div class="main-overlay__content" id="overlay-wrapper" aria-hidden="true">
    <div id="overlay-content"></div>
  </div>

  <!-- Info panel (slides in from left) -->
  <aside class="info-panel" id="info-panel" aria-hidden="true">
    <div class="info-panel__inner">

      <!-- Details column (fixed 45vw) -->
      <div class="info-panel__details">
        <button class="close-btn" id="info-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.2"/>
            <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </button>
        <div class="info-panel__scroll" id="info-scroll">
          <header class="info-panel__header">
            <p class="info-panel__name" id="info-name"></p>
            <p class="info-panel__year" id="info-year"></p>
          </header>
          <dl class="info-panel__meta">
            <dt>Materials</dt>
            <dd id="info-materials"></dd>
            <dt>Dimensions</dt>
            <dd id="info-dimensions"></dd>
          </dl>
          <p class="info-panel__description" id="info-description"></p>
        </div>
      </div>

      <!-- Gallery column (revealed when is-wide) -->
      <div class="info-panel__gallery" id="info-gallery">
        <div class="info-panel__gallery-scroll" id="info-gallery-scroll"></div>
      </div>

    </div>
  </aside>

  <!-- View / Collapse images toggle -->
  <button class="info-panel__expand" id="info-expand">View more images</button>

  <!-- Custom cursor label -->
  <div class="custom-cursor" id="custom-cursor" aria-hidden="true">
    <div class="custom-cursor__window">
      <span class="custom-cursor__text">CLICK TO DISCOVER</span>
    </div>
  </div>

  <!-- Backdrop: clicking outside info panel closes it -->
  <div class="info-backdrop" id="info-backdrop" aria-hidden="true"></div>

  <!-- Product scrubber: horizontal cluster, position tracks current product index -->
  <div class="piece-scrubber" id="piece-scrubber" aria-hidden="true">
    <button class="piece-scrubber__arrow piece-scrubber__arrow--left" id="arrow-left" aria-label="Previous product">
      <svg width="27" height="51" viewBox="0 0 18 34" fill="none" aria-hidden="true">
        <path d="M14 2 L14 32 L2 17 Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="piece-scrubber__arrow piece-scrubber__arrow--right" id="arrow-right" aria-label="Next product">
      <svg width="27" height="51" viewBox="0 0 18 34" fill="none" aria-hidden="true">
        <path d="M4 2 L4 32 L16 17 Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <!-- Image scrubber: position tracks current image index -->
  <div class="img-scrubber" id="img-scrubber" aria-hidden="true">
    <button class="img-scrubber__arrow img-scrubber__arrow--up" id="img-up" aria-label="Previous image">
      <svg width="51" height="27" viewBox="0 0 34 18" fill="none" aria-hidden="true">
        <path d="M2 15 L32 15 L17 3 Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="img-scrubber__arrow img-scrubber__arrow--down" id="img-down" aria-label="Next image">
      <svg width="51" height="27" viewBox="0 0 34 18" fill="none" aria-hidden="true">
        <path d="M2 3 L32 3 L17 15 Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</Layout>

<style>
  /* ── Gallery ─────────────────────────────────────── */

  .gallery {
    position: fixed;
    inset: 0;
    display: flex;
    overflow-x: scroll;
    overflow-y: hidden;
    scrollbar-width: none;
  }
  .gallery::-webkit-scrollbar { display: none; }

  .gallery__slide {
    position: relative;
    width: 100vw;       /* default for landscape; JS shrinks to auto for portrait */
    height: 100vh;
    flex-shrink: 0;
    cursor: default;
    overflow: hidden;
    background: #f5f4f0;
  }

  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    user-select: none;
    display: block;
  }

  .gallery__slide-title {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'SimSun', serif;
    font-size: 3.5rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: #e61515;
    white-space: nowrap;
    text-transform: uppercase;
    pointer-events: none;
    user-select: none;
  }

  /* ── Site header ─────────────────────────────────── */

  .site-header {
    position: fixed;
    top: 1.75rem;
    left: 2.25rem;
    z-index: 302;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .site-title {
    font-family: 'SimSun', serif;
    font-size: 3rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: #353269;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.35s ease, letter-spacing 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .site-title.is-overlay-active {
    pointer-events: auto;
    cursor: pointer;
  }

  :global(.site-title__char) {
    display: inline-block;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .site-title.is-hidden {
    opacity: 0;
  }

  /* ── Info button ─────────────────────────────────── */

  .info-btn {
    position: fixed;
    top: 1.75rem;
    right: 2.25rem;
    z-index: 303;
    color: #353269;
    line-height: 0;
    opacity: 1;
    transition: opacity 0.25s ease;
  }

  .info-btn.is-active {
    opacity: 0.5;
  }

  .info-btn__circle {
    display: block;
    width: 5.5rem;
    height: 5.5rem;
    overflow: visible;
    animation: info-spin 20s linear infinite;
  }

  @keyframes info-spin {
    to { transform: rotate(-360deg); }
  }

  .info-btn__circle text {
    font-family: 'SimSun', serif;
    font-size: 13px;
    font-weight: 700;
  }


  /* ── Main overlay ────────────────────────────────── */

  .main-overlay {
    position: fixed;
    inset: 0;
    background: rgba(252, 251, 249, 0.35);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    z-index: 300;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .main-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }



  .main-overlay__content {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 38ch;
    z-index: 303;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .main-overlay__content.show-content {
    opacity: 1;
    pointer-events: all;
  }

  .main-overlay__content a {
    color: #e61515;
    border-bottom: 1px solid rgba(230, 21, 21, 0.3);
    transition: border-color 0.15s;
  }

  .main-overlay__content a:hover {
    border-bottom-color: #e61515;
  }

  /* ── Shared close button ─────────────────────────── */

  .close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 1;
    color: #e61515;
    padding: 0.35rem;
    line-height: 0;
    transition: opacity 0.15s;
  }

  .close-btn:hover {
    opacity: 0.5;
  }

  /* ── Info panel ──────────────────────────────────── */

  .info-panel {
    position: fixed;
    top: 0;
    left: 0;
    width: 40%;
    height: 100vh;
    background: rgba(252, 251, 249, 0.75);
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    z-index: 200;
    transform: translateX(-100%);
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
  }

  .info-panel.is-open {
    transform: translateX(0);
  }

  .info-panel.is-wide {
    width: 100%;
  }

  .info-panel__inner {
    display: flex;
    flex-direction: row;
    height: 100%;
  }

  /* Left column: piece details */

  .info-panel__details {
    position: relative;
    width: calc(40vw + 6rem);
    min-width: calc(40vw + 6rem);
    flex-shrink: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .info-panel__scroll {
    flex: 1;
    overflow-y: auto;
    padding: 8rem 9rem 3.5rem 9.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    scrollbar-width: thin;
    scrollbar-color: #ddd transparent;
  }

  .info-panel__header {
    padding-top: 0.5rem;
  }

  .info-panel__name {
    font-family: 'SimSun', serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.1;
    color: #e61515;
    letter-spacing: 0.25em;
  }

  .info-panel__year {
    margin-top: 0.6rem;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #aaa;
  }

  .info-panel__meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6rem 1.75rem;
    align-items: baseline;
    width: 100%;
  }

  .info-panel__meta dt {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #bbb;
  }

  .info-panel__meta dd {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 11px;
    color: #444;
    line-height: 1.55;
  }

  .info-panel__description {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.03em;
    color: #444;
    line-height: 1.7;
    white-space: pre-line;
    width: 100%;
  }

  .info-panel__description:empty {
    display: none;
  }

  .info-panel__expand {
    position: fixed;
    left: 70vw;
    top: 50%;
    transform: translateX(-50%) translateY(-50%);
    font-family: 'SimSun', serif;
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    color: #e61515;
    padding: 1rem 0.5rem;
    writing-mode: vertical-lr;
    text-orientation: upright;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    z-index: 201;
  }

  .info-panel__expand.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  .info-panel__expand:hover {
    opacity: 0.5;
  }

  /* Right column: image gallery */

  .info-panel__gallery {
    flex: 1;
    min-width: 0;
    position: relative;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    border-left: 1px solid rgba(26, 26, 26, 0.06);
  }

  .info-panel.is-wide .info-panel__gallery {
    opacity: 1;
    pointer-events: all;
    transition: opacity 0.6s ease 0.6s;
  }

  .info-panel__gallery-scroll {
    position: absolute;
    inset: 0;
    overflow-y: scroll;
    scrollbar-width: none;
  }

  .info-panel__gallery-scroll::-webkit-scrollbar {
    display: none;
  }

  /* ── Nav arrows ─────────────────────────────────── */

  .piece-scrubber {
    position: fixed;
    /* fixed vertical position; horizontal (left) set by JS per product index */
    bottom: 2.5rem;
    left: 50%;
    z-index: 205;
    transform: translateX(-50%);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    color: #e61515;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease,
                left 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .piece-scrubber.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  .piece-scrubber__arrow {
    color: #e61515;
    padding: 1rem 0.5rem;
    line-height: 0;
    transition: opacity 0.25s ease;
  }

  .piece-scrubber__arrow.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Image scrubber ──────────────────────────────── */

  .img-scrubber {
    position: fixed;
    /* Right edge of the screen; vertical position (top) set by JS per image index */
    right: 3rem;
    top: 50%;
    z-index: 206;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    color: #e61515;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease,
                top 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .img-scrubber.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  .img-scrubber__arrow {
    color: #e61515;
    padding: 0.35rem 1rem;
    line-height: 0;
    transition: opacity 0.25s ease;
  }

  .img-scrubber__arrow.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Info panel backdrop ─────────────────────────── */

  .info-backdrop {
    position: fixed;
    inset: 0;
    z-index: 199;
    display: none;
  }

  .info-backdrop.is-active {
    display: block;
  }

  /* ── Custom cursor ───────────────────────────────── */

  .custom-cursor {
    display: none;
  }

  .custom-cursor.is-active {
    display: none;
  }

  .custom-cursor__window {
    overflow: hidden;
    width: 5.5rem;
    font-family: 'SimSun', serif;
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: #002ee6;
    white-space: nowrap;
    line-height: 1;
  }

  .custom-cursor__text {
    display: inline-block;
    animation: cursor-scroll 5s linear infinite;
  }

  @keyframes cursor-scroll {
    from { transform: translateX(5.5rem); }
    to   { transform: translateX(-100%); }
  }


  /* ── Responsive ──────────────────────────────────── */

  @media (max-width: 768px) {
    .info-panel {
      width: 100%;
    }

    .info-panel__details {
      width: 100%;
      min-width: unset;
    }

    .info-panel__scroll {
      padding: 4.5rem 1.75rem 2.75rem;
    }

    .info-panel__name {
      font-size: 1.875rem;
    }

    .info-panel__expand {
      display: none;
    }
  }
</style>

<style is:global>
  #overlay-content p,
  #overlay-content address {
    font-family: 'SimSun', serif;
    font-size: 16px;
    color: #030438;
    line-height: 1.7;
    margin-bottom: 0.875rem;
    font-style: normal;
  }
  #overlay-content p:last-child,
  #overlay-content address p:last-child {
    margin-bottom: 0;
  }

  .info-img-item {
    width: 100%;
    display: block;
  }

  .info-img-item img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
    user-select: none;
  }
</style>

<script define:vars={{ pieces: browserPieces }}>
  const gallery           = document.getElementById('gallery');
  const infoBtn           = document.getElementById('info-btn');
  const siteTitle         = document.querySelector('.site-title');
  const mainOverlay       = document.getElementById('main-overlay');
  const overlayWrapper    = document.getElementById('overlay-wrapper');
  const overlayContent    = document.getElementById('overlay-content');
  const infoPanel         = document.getElementById('info-panel');
  const infoBackdrop      = document.getElementById('info-backdrop');
  const infoClose         = document.getElementById('info-close');
  const infoName          = document.getElementById('info-name');
  const infoYear          = document.getElementById('info-year');
  const infoMaterials     = document.getElementById('info-materials');
  const infoDimensions    = document.getElementById('info-dimensions');
  const infoDescription   = document.getElementById('info-description');
  const infoExpand        = document.getElementById('info-expand');
  const infoScroll        = document.getElementById('info-scroll');
  const infoGalleryScroll = document.getElementById('info-gallery-scroll');
const arrowLeft         = document.getElementById('arrow-left');
  const arrowRight        = document.getElementById('arrow-right');
  const pieceScrubber     = document.getElementById('piece-scrubber');
  const imgScrubber       = document.getElementById('img-scrubber');
  const imgUp             = document.getElementById('img-up');
  const imgDown           = document.getElementById('img-down');

  const titleRawText = siteTitle.textContent;

  let currentPieceId = null;
  let currentIndex = 0;
  const gallerySlides = Array.from(gallery.querySelectorAll('.gallery__slide'));

  // ── Piece navigation ───────────────────────────────

  // Temporary spacers so slides can be centred before clones are ready
  const galStartSpacer = document.createElement('div');
  galStartSpacer.style.cssText = 'min-width:50vw;flex-shrink:0;height:100vh;';
  const galEndSpacer = document.createElement('div');
  galEndSpacer.style.cssText = 'min-width:50vw;flex-shrink:0;height:100vh;';
  gallery.insertBefore(galStartSpacer, gallerySlides[0]);
  gallery.appendChild(galEndSpacer);

  function scrollToSlide(idx, smooth) {
    const slide = gallerySlides[idx];
    if (!slide) return;
    const target = slide.offsetLeft + slide.offsetWidth / 2 - gallery.clientWidth / 2;
    gallery.scrollTo({ left: Math.max(0, target), behavior: smooth ? 'smooth' : 'instant' });
  }

  let cloneLastEl = null, cloneFirstEl = null;

  function setupInfiniteClones() {
    galStartSpacer.remove();
    galEndSpacer.remove();
    const N = gallerySlides.length;
    const firstSlide  = gallerySlides[0];
    const lastSlide   = gallerySlides[N - 1];
    // Outer context clones fill the viewport edge so no empty background flashes on wrap
    const penultSlide = gallerySlides[N - 2] || firstSlide;
    const secondSlide = gallerySlides[1]     || lastSlide;

    cloneLastEl  = lastSlide.cloneNode(true);
    cloneFirstEl = firstSlide.cloneNode(true);
    const cloneOuterLeft  = penultSlide.cloneNode(true);
    const cloneOuterRight = secondSlide.cloneNode(true);

    const copyStyles = (from, to) => {
      to.style.cssText = from.style.cssText;
      const fi = from.querySelector('.gallery__img');
      const ti = to.querySelector('.gallery__img');
      if (fi && ti) ti.style.cssText = fi.style.cssText;
    };
    copyStyles(lastSlide,   cloneLastEl);
    copyStyles(firstSlide,  cloneFirstEl);
    copyStyles(penultSlide, cloneOuterLeft);
    copyStyles(secondSlide, cloneOuterRight);

    // Strip order: [outerLeft][cloneLastEl][slide0…slideN-1][cloneFirstEl][outerRight]
    gallery.insertBefore(cloneLastEl, firstSlide);
    gallery.insertBefore(cloneOuterLeft, cloneLastEl);
    gallery.appendChild(cloneFirstEl);
    gallery.appendChild(cloneOuterRight);

    scrollToSlide(currentIndex, false);
  }

  // All slides fit to viewport height with natural width — adjacent slides peek in on both sides
  let loadedCount = 0;
  gallerySlides.forEach(slide => {
    const img = slide.querySelector('.gallery__img');
    if (!img) return;
    const check = () => {
      slide.style.width = 'auto';
      img.style.width = 'auto';
      img.style.objectFit = 'unset';
      loadedCount++;
      if (loadedCount === gallerySlides.length) setupInfiniteClones();
      else scrollToSlide(currentIndex, false);
    };
    if (img.complete && img.naturalWidth) check();
    else img.addEventListener('load', check);
  });

  scrollToSlide(0, false);

  let isNavigating = false;

  // Horizontal product scrubber — position tracks current product index across the
  // screen width (near left on product 1, near right on the last), mirroring the
  // vertical image scrubber. Available in the main view and the product overlay.
  function updateArrows(instant) {
    const N      = pieces.length;
    const active = N > 1 && !mainOverlay.classList.contains('is-open');

    pieceScrubber.classList.toggle('is-visible', active);
    pieceScrubber.setAttribute('aria-hidden', active ? 'false' : 'true');
    if (!active) return;

    const idx    = currentIndex;
    const inset  = window.innerWidth * 0.18;          // keep cluster clear of edges
    const usable = window.innerWidth - inset * 2;
    const x      = inset + (idx / (N - 1)) * usable;

    if (instant) {
      pieceScrubber.style.transition = 'none';
      pieceScrubber.style.left = `${x}px`;
      pieceScrubber.offsetHeight; // force reflow before re-enabling transition
      pieceScrubber.style.transition = '';
    } else {
      pieceScrubber.style.left = `${x}px`;
    }

    arrowLeft.classList.remove('is-hidden');
    arrowRight.classList.remove('is-hidden');
  }

  function animatedScrollTo(targetLeft, duration, callback) {
    const startLeft = gallery.scrollLeft;
    const delta = Math.max(0, targetLeft) - startLeft;
    const startTime = performance.now();
    function ease(t) { return t < 0.5 ? 2*t*t : -1 + (4 - 2*t)*t; }
    function step(now) {
      const t = Math.min((now - startTime) / duration, 1);
      gallery.scrollLeft = startLeft + delta * ease(t);
      if (t < 1) requestAnimationFrame(step);
      else if (callback) callback();
    }
    requestAnimationFrame(step);
  }

  function navigatePiece(direction) {
    if (isNavigating) return;
    isNavigating = true;
    const N = pieces.length;

    if (direction === -1 && currentIndex === 0 && cloneLastEl) {
      currentIndex = N - 1;
      const t = cloneLastEl.offsetLeft + cloneLastEl.offsetWidth / 2 - gallery.clientWidth / 2;
      animatedScrollTo(Math.max(0, t), 550, () => {
        scrollToSlide(N - 1, false);
        isNavigating = false;
      });
    } else if (direction === 1 && currentIndex === N - 1 && cloneFirstEl) {
      currentIndex = 0;
      const t = cloneFirstEl.offsetLeft + cloneFirstEl.offsetWidth / 2 - gallery.clientWidth / 2;
      animatedScrollTo(Math.max(0, t), 550, () => {
        scrollToSlide(0, false);
        isNavigating = false;
      });
    } else {
      currentIndex = (currentIndex + direction + N) % N;
      scrollToSlide(currentIndex, true);
      setTimeout(() => { isNavigating = false; }, 700);
    }

    updateArrows();
    updateCursor(lastMouseX, lastMouseY);
  }

  arrowLeft.addEventListener('click',  (e) => {
    e.stopPropagation();
    if (infoPanel.classList.contains('is-open')) switchPiece(-1); else navigatePiece(-1);
  });
  arrowRight.addEventListener('click', (e) => {
    e.stopPropagation();
    if (infoPanel.classList.contains('is-open')) switchPiece(1); else navigatePiece(1);
  });

  updateArrows(true);

  // Track scrubber in real-time as the gallery scrolls (trackpad, mouse, or programmatic)
  gallery.addEventListener('scroll', () => {
    if (gallerySlides.length < 2) return;
    const N = pieces.length;
    const first = gallerySlides[0];
    const last  = gallerySlides[N - 1];
    const firstCentre = first.offsetLeft + first.offsetWidth / 2;
    const lastCentre  = last.offsetLeft  + last.offsetWidth  / 2;
    const viewCentre  = gallery.scrollLeft + gallery.clientWidth / 2;
    // Wrap frac for clone zones so scrubber reflects the looped position
    let frac;
    if (viewCentre < firstCentre)      frac = 1; // in clone-last zone → show as last slide
    else if (viewCentre > lastCentre)  frac = 0; // in clone-first zone → show as first slide
    else frac = (viewCentre - firstCentre) / (lastCentre - firstCentre);
    const inset  = window.innerWidth * 0.18;
    const usable = window.innerWidth - inset * 2;
    pieceScrubber.style.transition = 'opacity 0.3s ease'; // suppress left transition during live scroll
    pieceScrubber.style.left = `${inset + frac * usable}px`;
    currentIndex = Math.round(frac * (N - 1));
  });

  // After scroll settles: if we landed on a clone, silently jump to the real slide
  gallery.addEventListener('scrollend', () => {
    pieceScrubber.style.transition = ''; // restore full transition
    const N = pieces.length;
    const viewCentre  = gallery.scrollLeft + gallery.clientWidth / 2;
    const firstCentre = gallerySlides[0].offsetLeft + gallerySlides[0].offsetWidth / 2;
    const lastCentre  = gallerySlides[N - 1].offsetLeft + gallerySlides[N - 1].offsetWidth / 2;
    if (viewCentre < firstCentre && cloneLastEl) {
      currentIndex = N - 1;
      scrollToSlide(N - 1, false);
    } else if (viewCentre > lastCentre && cloneFirstEl) {
      currentIndex = 0;
      scrollToSlide(0, false);
    }
    updateArrows();
  });

  function updateTitle() {
    const anyOpen = infoPanel.classList.contains('is-open') || mainOverlay.classList.contains('is-open');
    siteTitle.classList.toggle('is-panel-open', infoPanel.classList.contains('is-open'));
    siteTitle.classList.toggle('is-overlay-active', anyOpen);
  }

  // ── About / Contact overlay ────────────────────────

  const overlayText = {
    about: `
      <p>Furniture made by hand in Frome, Somerset.</p>
      <p>Each piece begins with the material — its grain, weight, and character — and ends only when it feels resolved.</p>
      <p>The work is quiet by intention. Designed to be used, and to last.</p>
      <p>Available for commissions. Lead time is typically twelve to sixteen weeks.</p>
    `,
    contact: `
      <address>
        <p><a href="mailto:info@frankstyles.co.uk">info@frankstyles.co.uk</a></p>
        <p>Frome, Somerset</p>
<p></p>
        <p>Workshop visits by appointment.</p>
      </address>
    `,
  };

  infoBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (mainOverlay.classList.contains('is-open')) { dismissOverlay(); } else { openInfo(); }
  });

  function activateInfoBtn() {
    infoBtn.classList.add('is-active');

    // Measure title while it is still plain text
    const remPx        = parseFloat(getComputedStyle(document.documentElement).fontSize);
    const badgeAreaPx  = (2.25 + 5.5) * remPx;
    const titleRect    = siteTitle.getBoundingClientRect();
    const availWidth   = window.innerWidth - badgeAreaPx - titleRect.left;
    const titleFs      = parseFloat(getComputedStyle(siteTitle).fontSize);
    const titleChars   = siteTitle.textContent.length;
    const currentLsPx  = parseFloat(getComputedStyle(siteTitle).letterSpacing);
    const naturalWidth = siteTitle.offsetWidth - titleChars * currentLsPx;
    const titleLsEm    = Math.max((availWidth - naturalWidth) / titleChars / titleFs, 0.25);
    siteTitle.style.letterSpacing = `${titleLsEm}em`;

    // Build per-character spans (title is still plain text, so textContent is correct)
    const raw = siteTitle.textContent;
    siteTitle.textContent = '';
    raw.split('').forEach(ch => {
      const s = document.createElement('span');
      s.className      = 'site-title__char';
      s.style.display  = 'inline-block';
      s.style.transition = 'transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94), color 0.45s ease, opacity 0.45s ease';
      s.textContent    = ch;
      siteTitle.appendChild(s);
    });

    const charSpans = Array.from(siteTitle.querySelectorAll('.site-title__char'))
      .filter(s => s.textContent !== ' ');

    siteTitle.offsetHeight; // commit initial state before transforms

    // Fold a value back within [min, max] with ricochet reflection
    function ricochet(val, min, max) {
      const range = max - min;
      if (range <= 0) return min;
      let v = ((val - min) % (2 * range) + 2 * range) % (2 * range);
      if (v > range) v = 2 * range - v;
      return v + min;
    }

    const PAD   = 28; // px from each screen edge
    const TRIES = 30;
    const placed = [];

    charSpans.forEach(span => {
      const r     = span.getBoundingClientRect();
      const baseX = r.left + r.width / 2;
      const baseY = r.top  + r.height / 2;
      let bestDx = 0, bestDy = 0, bestScore = -1;
      for (let i = 0; i < TRIES; i++) {
        // Raw offsets larger than the viewport so ricochets occur naturally
        const rawDx = (Math.random() - 0.5) * window.innerWidth  * 1.6;
        const rawDy = (Math.random() - 0.5) * window.innerHeight * 1.6;
        const ax = ricochet(baseX + rawDx, PAD, window.innerWidth  - PAD);
        const ay = ricochet(baseY + rawDy, PAD, window.innerHeight - PAD);
        const dx = ax - baseX, dy = ay - baseY;
        let minD = Infinity;
        for (const p of placed) minD = Math.min(minD, Math.hypot(ax - p.x, ay - p.y));
        if (placed.length === 0) minD = Infinity;
        if (minD > bestScore) { bestScore = minD; bestDx = dx; bestDy = dy; }
      }
      placed.push({ x: baseX + bestDx, y: baseY + bestDy });
      const rot = (Math.random() - 0.5) * 40;
      span.style.color     = '#2c6639';
      span.style.opacity   = '0.45';
      span.style.transform = `translateX(${bestDx}px) translateY(${bestDy}px) rotate(${rot}deg)`;
    });
  }

  function deactivateInfoBtn() {
    infoBtn.classList.remove('is-active');
    const resetSpans = Array.from(siteTitle.querySelectorAll('.site-title__char'));
    if (resetSpans.length) {
      // Animate spans back to base positions — letterSpacing stays spread so base positions don't shift
      resetSpans.forEach(span => { span.style.transform = ''; span.style.color = ''; span.style.opacity = ''; });
      setTimeout(() => {
        // Atomically swap text + reset letterSpacing in a single frame with no transition
        siteTitle.style.transition = 'none';
        siteTitle.style.letterSpacing = '';
        siteTitle.textContent = titleRawText;
        siteTitle.offsetHeight; // force reflow before restoring transition
        siteTitle.style.transition = '';
      }, 460);
    } else {
      siteTitle.style.letterSpacing = '';
    }
  }

  function openInfo() {
    overlayContent.innerHTML = overlayText.about + overlayText.contact;
    mainOverlay.classList.add('is-open');
    overlayWrapper.classList.add('show-content');
    overlayWrapper.setAttribute('aria-hidden', 'false');
    mainOverlay.setAttribute('aria-hidden', 'false');
    activateInfoBtn();
    updateTitle();
    updateCursor(lastMouseX, lastMouseY);
  }

  function dismissOverlay() {
    mainOverlay.classList.remove('is-open');
    overlayWrapper.classList.remove('show-content');
    overlayWrapper.setAttribute('aria-hidden', 'true');
    mainOverlay.setAttribute('aria-hidden', 'true');
    deactivateInfoBtn();
    updateTitle();
    updateCursor(lastMouseX, lastMouseY);
  }

  document.addEventListener('click', (e) => {
    if (!mainOverlay.classList.contains('is-open')) return;
    if (infoBtn.contains(e.target)) return;
    dismissOverlay();
  });

  // ── Gallery click → info panel ─────────────────────

  gallery.addEventListener('click', (e) => {
    if (mainOverlay.classList.contains('is-open')) {
      dismissOverlay();
      return;
    }
    if (infoPanel.classList.contains('is-open')) return;
    if (!cursorInZone) return;
    openInfoPanel(pieces[currentIndex].id);
  });

  // Write a piece's text details into the panel
  function setPieceDetails(piece) {
    infoName.textContent        = piece.name;
    infoYear.textContent        = piece.year;
    infoMaterials.textContent   = piece.materials;
    infoDimensions.textContent  = piece.dimensions;
    infoDescription.textContent = piece.description || '';
  }

  // (Re)build the scroll gallery for a piece. Assumes the gallery column has its
  // final dimensions (panel already is-wide) so item heights measure correctly.
  function buildGallery(piece) {
    infoGalleryScroll.innerHTML = '';
    infoGalleryScroll.scrollTop = 0;
    const imgs = piece.additionalImages || [];
    if (!imgs.length) return;
    imgs.forEach(imgData => {
      const item = document.createElement('div');
      item.className = 'info-img-item';
      const img = document.createElement('img');
      img.src = imgData.src ?? imgData;
      img.alt = piece.name;
      item.appendChild(img);
      infoGalleryScroll.appendChild(item);
    });
    infoGalleryScroll.scrollTop = 0;
  }

  function applyImgFit(img) {
    const check = () => {
      if (img.naturalWidth > img.naturalHeight) img.style.objectFit = 'contain';
    };
    if (img.complete && img.naturalWidth) check(); else img.addEventListener('load', check);
  }

  // Snap gallery to idx instantly. Used to keep the background in sync when the overlay closes.
  function placeMainGallery(idx) {
    currentIndex = idx;
    scrollToSlide(idx, false);
  }

  // Swap the active product in place while the overlay stays open
  let isSwitching = false;
  const SWITCH_DUR = 220;

  function switchPiece(direction) {
    if (!infoPanel.classList.contains('is-open')) return;
    if (isSwitching) return;
    const N = pieces.length;
    if (N < 2) return;

    const curIdx  = pieces.findIndex(p => p.id === currentPieceId);
    const nextIdx = (curIdx + direction + N) % N;
    const piece   = pieces[nextIdx];

    isSwitching = true;
    currentPieceId = piece.id;
    placeMainGallery(nextIdx);
    updateArrows();

    // Slide current content out in direction of travel
    infoScroll.style.transition = `opacity ${SWITCH_DUR}ms ease, transform ${SWITCH_DUR}ms ease`;
    infoScroll.style.opacity   = '0';
    infoScroll.style.transform = `translateX(${-direction * 80}px)`;

    if (infoGalleryScroll.children.length) {
      infoGalleryScroll.style.transition = `opacity ${SWITCH_DUR}ms ease`;
      infoGalleryScroll.style.opacity   = '0';
    }

    setTimeout(() => {
      setPieceDetails(piece);

      if (piece.additionalImages && piece.additionalImages.length) {
        if (!infoPanel.classList.contains('is-wide')) {
          infoPanel.style.transition = 'none';
          infoPanel.classList.add('is-wide');
          infoPanel.offsetHeight;
          infoPanel.style.transition = '';
        }
        buildGallery(piece);
      } else {
        infoGalleryScroll.innerHTML = '';
        infoPanel.classList.remove('is-wide');
      }
      infoExpand.classList.remove('is-visible');

      // Snap new content to incoming side, then slide it in
      infoScroll.style.transition = 'none';
      infoScroll.style.transform  = `translateX(${direction * 80}px)`;
      infoScroll.offsetHeight;
      infoScroll.style.transition = `opacity ${SWITCH_DUR}ms ease, transform ${SWITCH_DUR}ms ease`;
      infoScroll.style.opacity    = '1';
      infoScroll.style.transform  = 'translateX(0)';

      infoGalleryScroll.style.transition = `opacity ${SWITCH_DUR}ms ease`;
      infoGalleryScroll.style.opacity    = '1';

      setTimeout(() => {
        infoScroll.style.transition = '';
        infoScroll.style.opacity    = '';
        infoScroll.style.transform  = '';
        infoGalleryScroll.style.transition = '';
        infoGalleryScroll.style.opacity    = '';
        isSwitching = false;
      }, SWITCH_DUR);

      requestAnimationFrame(() => { infoGalleryScroll.scrollTop = 0; updateImgScrubber(true); });
      updateImgScrubber(true);
      updateCursor(lastMouseX, lastMouseY);
    }, SWITCH_DUR);
  }

  function openInfoPanel(id) {
    const piece = pieces.find(p => p.id === id);
    if (!piece) return;
    currentPieceId = id;

    setPieceDetails(piece);

    if (piece.additionalImages && piece.additionalImages.length) {
      infoGalleryScroll.innerHTML = '';

      // Apply is-wide instantly FIRST so the gallery column reaches its real dimensions
      infoPanel.style.transition = 'none';
      infoPanel.classList.add('is-wide');
      infoPanel.offsetHeight; // force reflow — gallery now has correct clientHeight
      infoPanel.style.transition = '';

      buildGallery(piece);
      requestAnimationFrame(() => { infoGalleryScroll.scrollTop = 0; updateImgScrubber(true); });
    } else {
      infoGalleryScroll.innerHTML = '';
    }

    infoPanel.classList.add('is-open');
    infoExpand.classList.remove('is-visible');
    updateImgScrubber(true);

    infoPanel.setAttribute('aria-hidden', 'false');
    infoBackdrop.classList.add('is-active');
    updateTitle();
    updateArrows();
    updateCursor(lastMouseX, lastMouseY);
  }

  function openExpanded() {
    const piece = pieces.find(p => p.id === currentPieceId);
    if (!piece || !piece.additionalImages || !piece.additionalImages.length) return;

    infoGalleryScroll.innerHTML = '';
    piece.additionalImages.forEach(imgData => {
      const item = document.createElement('div');
      item.className = 'info-img-item';
      const img = document.createElement('img');
      img.src = imgData.src ?? imgData;
      img.alt = piece.name;
      item.appendChild(img);
      infoGalleryScroll.appendChild(item);
    });

    infoPanel.classList.add('is-wide');
    infoExpand.classList.remove('is-visible');
    requestAnimationFrame(() => updateImgScrubber(true));
  }

  function closeExpanded() {
    infoPanel.classList.remove('is-wide');
    infoExpand.innerHTML = 'View more images';
    infoExpand.classList.add('is-visible');
    updateImgScrubber();
  }

  function closeInfoPanel() {
    infoPanel.classList.remove('is-open', 'is-wide');
    infoPanel.setAttribute('aria-hidden', 'true');
    infoBackdrop.classList.remove('is-active');
    updateImgScrubber();
    infoExpand.innerHTML = 'View more images';
    infoExpand.classList.remove('is-visible');
    setTimeout(() => {
      infoGalleryScroll.innerHTML = '';
      infoGalleryScroll.scrollTop = 0;
    }, 460);
    currentPieceId = null;
    updateTitle();
    updateArrows();
    updateCursor(lastMouseX, lastMouseY);
  }

  infoExpand.addEventListener('click', openExpanded);
infoClose.addEventListener('click', closeInfoPanel);
  infoBackdrop.addEventListener('click', closeInfoPanel);

  siteTitle.addEventListener('click', () => {
    if (infoPanel.classList.contains('is-open')) closeInfoPanel();
    if (mainOverlay.classList.contains('is-open')) dismissOverlay();
  });

  // ── Image scrubber ──────────────────────────────────

  function getGalleryItems() {
    return Array.from(infoGalleryScroll.querySelectorAll('.info-img-item'));
  }

  // Image whose centre is closest to the scroll container's centre
  function currentImgIndex() {
    const items = getGalleryItems();
    if (!items.length) return 0;
    const viewCentre = infoGalleryScroll.scrollTop + infoGalleryScroll.clientHeight / 2;
    let best = 0, bestDist = Infinity;
    items.forEach((it, i) => {
      const d = Math.abs((it.offsetTop + it.offsetHeight / 2) - viewCentre);
      if (d < bestDist) { bestDist = d; best = i; }
    });
    return best;
  }

  function scrollToImg(idx) {
    const items = getGalleryItems();
    if (!items[idx]) return;
    const item = items[idx];
    const target = item.offsetTop + item.offsetHeight / 2 - infoGalleryScroll.clientHeight / 2;
    infoGalleryScroll.scrollTo({ top: Math.max(0, target), behavior: 'smooth' });
  }

  // Position the cluster at (index / (N-1)) of the usable height + toggle arrows
  function updateImgScrubber(instant) {
    const items  = getGalleryItems();
    const N      = items.length;
    const active = infoPanel.classList.contains('is-open')
      && infoPanel.classList.contains('is-wide')
      && N > 1;

    imgScrubber.classList.toggle('is-visible', active);
    imgScrubber.setAttribute('aria-hidden', active ? 'false' : 'true');
    if (!active) return;

    const idx    = currentImgIndex();
    const inset  = window.innerHeight * 0.18;          // keep cluster clear of edges
    const usable = window.innerHeight - inset * 2;
    const y      = inset + (idx / (N - 1)) * usable;

    if (instant) {
      imgScrubber.style.transition = 'none';
      imgScrubber.style.top = `${y}px`;
      imgScrubber.offsetHeight; // force reflow before re-enabling transition
      imgScrubber.style.transition = '';
    } else {
      imgScrubber.style.top = `${y}px`;
    }

    imgUp.classList.toggle('is-hidden', idx <= 0);
    imgDown.classList.toggle('is-hidden', idx >= N - 1);
  }

  imgUp.addEventListener('click',   () => scrollToImg(currentImgIndex() - 1));
  imgDown.addEventListener('click', () => scrollToImg(currentImgIndex() + 1));

  let scrubberTick = false;
  infoGalleryScroll.addEventListener('scroll', () => {
    if (scrubberTick) return;
    scrubberTick = true;
    requestAnimationFrame(() => { scrubberTick = false; updateImgScrubber(); });
  });

  window.addEventListener('resize', () => { updateImgScrubber(true); updateArrows(true); });

  // ── Escape key ─────────────────────────────────────

  // ── Custom cursor ──────────────────────────────────
  const customCursor = document.getElementById('custom-cursor');

  function isOverlayActive() {
    return infoPanel.classList.contains('is-open')
      || mainOverlay.classList.contains('is-open');
  }

  function updateCursor(x, y) {
    customCursor.style.left = x + 'px';
    customCursor.style.top  = y + 'px';
    const w = window.innerWidth;
    const h = window.innerHeight;
    cursorInZone = x > w * 0.125 && x < w * 0.875 && y > h * 0.125 && y < h * 0.875;
    const show = cursorInZone && !isOverlayActive();
    customCursor.classList.toggle('is-active', show);
    document.body.classList.toggle('cursor-zone-active', show);
  }

  let lastMouseX = -1, lastMouseY = -1;
  let cursorInZone = false;
  document.addEventListener('mousemove', (e) => {
    lastMouseX = e.clientX;
    lastMouseY = e.clientY;
    updateCursor(lastMouseX, lastMouseY);
  });
  document.addEventListener('mouseleave', () => {
    customCursor.classList.remove('is-active');
    document.body.classList.remove('cursor-zone-active');
  });

  // ── Escape key ─────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (infoPanel.classList.contains('is-open')) {
        closeInfoPanel();
      } else {
        dismissOverlay();
      }
      return;
    }
    // Product overlay open: up/down scrub images, left/right switch products in place
    if (infoPanel.classList.contains('is-open')) {
      if (infoPanel.classList.contains('is-wide')) {
        if (e.key === 'ArrowUp')   { e.preventDefault(); scrollToImg(currentImgIndex() - 1); }
        if (e.key === 'ArrowDown') { e.preventDefault(); scrollToImg(currentImgIndex() + 1); }
      }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); switchPiece(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); switchPiece(1); }
      return;
    }

    // Main view: left/right switch pieces (up/down disabled here)
    if (!mainOverlay.classList.contains('is-open')) {
      if (e.key === 'ArrowLeft')  navigatePiece(-1);
      if (e.key === 'ArrowRight') navigatePiece(1);
    }
  });

  // ── Circular title: "INFO AND CONTACT AND" ──────────
  // Each character occupies one equal angular slot around the circle; spaces are
  // blank slots, so inter-letter and inter-word spacing share the same unit. The
  // trailing space makes the wrap gap (last AND → INFO) match the other word gaps.
  (function buildInfoCircle() {
    const svg = document.getElementById('info-circle');
    if (!svg) return;
    const SVGNS = 'http://www.w3.org/2000/svg';
    const cx = 50, cy = 50, r = 40;
    const RED = '#e61515';   // same red as nav arrows
    const BLUE = '#353269';  // same blue as the main title
    const segments = [
      ['INFO', RED], [' ', null], ['AND', BLUE], [' ', null],
      ['CONTACT', RED], [' ', null], ['AND', BLUE], [' ', null],
    ];
    const chars = [];
    segments.forEach(([word, color]) => {
      for (const ch of word) chars.push({ ch, color });
    });
    const n = chars.length;
    chars.forEach(({ ch, color }, i) => {
      if (ch === ' ') return; // blank slot — keeps spacing equal across words
      const phi = (i / n) * 360;                 // degrees clockwise from top
      const rad = (phi - 90) * Math.PI / 180;
      const x = cx + r * Math.cos(rad);
      const y = cy + r * Math.sin(rad);
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', x);
      t.setAttribute('y', y);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dominant-baseline', 'central');
      t.setAttribute('transform', `rotate(${phi} ${x} ${y})`);
      t.setAttribute('fill', color);
      t.setAttribute('font-weight', '700');
      t.textContent = ch;
      svg.appendChild(t);
    });
  })();
</script>
