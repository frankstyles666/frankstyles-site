---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'SimSun';
    src: url('/fonts/SimSun/SimSun Regular/SimSun Regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    overflow: hidden;
  }

  body {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14px;
    color: #1a1a1a;
    background: #0a0a0a;
  }

  button {
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ::selection {
    background-color: #353269;
    color: #e61515;
  }

  img {
    max-width: 100%;
    display: block;
  }

  address {
    font-style: normal;
  }
</style>
